{
  "name": "k2gl/sigstore-sign",
  "description": "Sign artifacts and attestations with Sigstore from PHP — sign, log to Rekor, timestamp, and assemble a bundle",
  "homepage": "https://github.com/k2gl/sigstore-sign",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "sigstore",
    "signing",
    "cosign",
    "rekor",
    "dsse",
    "attestation",
    "timestamp",
    "rfc3161",
    "supply-chain"
  ],
  "authors": [
    {
      "name": "Nick Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/sigstore-sign/issues",
    "source": "https://github.com/k2gl/sigstore-sign"
  },
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.1|^2.0",
    "k2gl/dsse": "^1.3",
    "k2gl/sigstore-bundle": "^1.0",
    "k2gl/rekor-client": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10|^11|^12",
    "phpstan/phpstan": "^2.1",
    "laravel/pint": "~1.20.0",
    "k2gl/phpunit-fluent-assertions": "^12",
    "nyholm/psr7": "^1.8",
    "k2gl/composer-attest": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "k2gl/composer-attest": true
    }
  },
  "extra": {
    "k2gl-attest": {
      "mode": "warn"
    }
  },
  "autoload": {
    "psr-4": {
      "K2gl\\SigstoreSign\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "K2gl\\SigstoreSign\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "pint --test",
    "cs-fix": "pint",
    "check": [
      "@test",
      "@phpstan",
      "@cs"
    ]
  }
}
